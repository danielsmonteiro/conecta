# Proxy reverso do Conecta. O domínio vem 100% de APP_DOMAIN (.env) — trocar o
# nome = trocar essa env e recriar o caddy; o certificado TLS é reemitido sozinho.
{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	encode gzip zstd

	# /api/* vai DIRETO ao backend (preserva o prefixo /api). Evita o gotcha de
	# rewrites do Next em build standalone e é mais eficiente (não passa pelo Next).
	@api path /api/*
	reverse_proxy @api backend:3000

	# Todo o resto é o frontend (Next).
	reverse_proxy frontend:3000
}
