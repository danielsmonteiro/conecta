# Proxy reverso compartilhado: serve PROD e DEV no mesmo Caddy (um só dono de 80/443).
# Domínios parametrizados (APP_DOMAIN = prod, DEV_DOMAIN = dev). Alvos por nome de
# container porque o Caddy está anexado às redes dos dois projetos (prod e dev), onde
# os nomes de serviço 'frontend'/'backend' colidiriam.
{
	email {$ACME_EMAIL}
}

# ---- Produção ----
{$APP_DOMAIN} {
	encode gzip zstd
	@api path /api/*
	reverse_proxy @api healthmatch-prod-backend-1:3000
	reverse_proxy healthmatch-prod-frontend-1:3000
}

# ---- Desenvolvimento ----
{$DEV_DOMAIN} {
	encode gzip zstd
	@api path /api/*
	reverse_proxy @api healthmatch-dev-backend-1:3000
	reverse_proxy healthmatch-dev-frontend-1:3000
}
