# Banco de dados (PostgreSQL — ajuste conforme seu ambiente)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/healthmatch?schema=public"

# Servidor
PORT=3000
# Origem do frontend para CORS com cookies
CORS_ORIGIN=http://localhost:3001

# JWT — access token de curta duração + refresh (modelo observado em produção)
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso
JWT_ACCESS_TTL=900            # 15 min em segundos
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_REFRESH_TTL=604800        # 7 dias em segundos
COOKIE_SECURE=false           # true em produção (HTTPS)

# --------------------------- WhatsApp / Mensageria ---------------------------
# Provedor de envio INICIAL: 'twilio' (oficial, recomendado p/ piloto) | 'openwa'.
# Em runtime, a flag persistida (tela Integrações → Canais de WhatsApp, ou
# POST /api/integrations/messaging/active) tem prioridade sobre esta env.
MESSAGING_PROVIDER=twilio
# URL pública do backend (para montar a URL na validação de assinatura do webhook)
PUBLIC_BASE_URL=https://api.seu-dominio.com.br
# Drain da fila de saída (retry simples em memória)
MESSAGING_DRAIN_ENABLED=true
MESSAGING_DRAIN_INTERVAL_MS=10000

# --- Twilio (OFICIAL — WhatsApp Business API) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=         # ex.: +14155238886 (número/sandbox WhatsApp)
TWILIO_MESSAGING_SERVICE_SID= # opcional (alternativa ao FROM)
TWILIO_VALIDATE_SIGNATURE=true
# Webhook a configurar no Twilio: {PUBLIC_BASE_URL}/api/integrations/webhooks/twilio

# --- OpenWA (NÃO-OFICIAL — automação WhatsApp Web; risco de BAN do número) ---
# App SEPARADO (rede docker compartilhada). Use número DEDICADO. Default = Twilio.
# Ver ROADMAP_TECNICO.md e a seção OpenWA no README de integração.
OPENWA_BASE_URL=http://openwa-api:2785   # nome do serviço na rede openwa-network
OPENWA_API_KEY=                           # = API_MASTER_KEY do OpenWA (header X-API-Key)
OPENWA_SESSION=default                     # nome da sessão (vai na URL do endpoint)
OPENWA_WEBHOOK_SECRET=                     # segredo do webhook (validação de origem)
OPENWA_VALIDATE_WEBHOOK=true               # 'false' só durante o bring-up/QR
# No OpenWA, registre o webhook apontando para o backend (mesma rede):
#   url: http://backend:3000/api/integrations/webhooks/openwa
#   events: ["message.received","session.status"]

# --------------------------- IA (Épico 2 — Anthropic) ------------------------
AI_ENABLED=true
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
AI_DRY_RUN=true              # true = não envia de fato (validação no piloto)
AI_AUTO_REPLY=false
AI_REQUIRE_HUMAN=true
