# Copie este arquivo para `.env` e preencha com suas credenciais reais.
# NUNCA comite o arquivo `.env` (ja esta no .gitignore).

# URL da pagina de login
HEALTHMATCH_URL=https://healthmatch.appinstituto.com.br/login

# Credenciais de acesso (do proprietario do sistema)
HEALTHMATCH_USER=seu-email@exemplo.com
HEALTHMATCH_PASSWORD=sua-senha

# --- Opcionais (tem defaults sensatos) ---
# Profundidade maxima do crawler (default 3)
HEALTHMATCH_MAX_DEPTH=3
# Numero maximo de rotas a visitar (trava de seguranca, default 80)
HEALTHMATCH_MAX_PAGES=80
# Timeout por pagina em ms (default 20000)
HEALTHMATCH_PAGE_TIMEOUT=20000
# headless=false para acompanhar o navegador (default true)
HEALTHMATCH_HEADLESS=true
# Permitir cliques em elementos de navegacao (tabs/menus). Conservador por padrao.
HEALTHMATCH_ALLOW_NAV_CLICKS=true
